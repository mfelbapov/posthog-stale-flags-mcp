{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ALLOW_PROD": "false"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm exec:*)",
      "Bash(rg:*)",
      "Bash(biome:*)",
      "Bash(pnpm biome:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Edit(/.claude/skills/commit-and-push/**)",
      "Edit(/.claude/skills/push-merge-main/**)",
      "Edit(/.claude/skills/add-scenario/**)",
      "Edit(/.claude/skills/propagate-shared-change/**)",
      "Edit(/.claude/skills/freeze-feature/**)",
      "Edit(/.claude/skills/unfreeze-feature/**)",
      "Edit(/features/**)",
      "Edit(/test/features/**)",
      "Edit(/scripts/**)",
      "Bash(node scripts/check-features.mjs:*)",
      "Bash(scripts/hooks/pre-commit:*)",
      "Bash(chmod +x:*)",
      "Bash(bash -n:*)",
      "Bash(git fetch *)",
      "Bash(git merge *)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(gh pr:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
